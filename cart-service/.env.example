APP_ENVIRONMENT="development"
APP_NAME="cart-service"
APP_LOGGER_LEVEL=5
APP_TIMEOUT_SHUTDOWN=10s

METRICS_ENABLED=true
METRICS_PATH="/metrics"

TRACING_ENABLED=true
TRACING_URL="localhost:4318"
TRACING_SERVICE_NAME="cart-service"
TRACING_SAMPLING_RATE=0.1
TRACING_ENVIRONMENT="development"
TRACING_BATCH_TIMEOUT=5s
TRACING_EXPORT_TIMEOUT=30s

HTTP_SERVER_HOST=172.19.0.1
HTTP_SERVER_PORT=8089
HTTP_SERVER_GRACE_PERIOD=10s
HTTP_SERVER_REQUEST_TIMEOUT_PERIOD=30s
HTTP_SERVER_READ_TIMEOUT=30s
HTTP_SERVER_WRITE_TIMEOUT=30s
HTTP_SERVER_IDLE_TIMEOUT=120s
HTTP_SERVER_READ_HEADER_TIMEOUT=10s
HTTP_SERVER_MAX_HEADER_BYTES=1048576
HTTP_SERVER_HSTS_MAX_AGE=3600
HTTP_SERVER_RATE_LIMITER=1000

CONSUL_ADDRESS=localhost:8500
CONSUL_ENABLED=true

POSTGRES_HOST="localhost"
POSTGRES_PORT=15439
POSTGRES_DB="cart_db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_SSL_MODE="disable"
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_MAX_OPEN_CONNS=32
POSTGRES_MAX_CONN_LIFETIME=60s

REDIS_ADDRS=localhost:6379,localhost:6380,localhost:6381,localhost:6382,localhost:6383,localhost:6384
REDIS_PASSWORD=supersecret
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=1s
REDIS_MIN_IDLE_CONN=8
REDIS_MAX_IDLE_CONN=12
REDIS_MAX_ACTIVE_CONN=32
REDIS_MAX_CONN_LIFETIME=60s

KAFKA_BROKERS=localhost:9092,localhost:9092,localhost:9092
KAFKA_RETRY_MAX=3
KAFKA_FLUSH_FREQUENCY=500
KAFKA_RETURN_SUCCESS=true
KAFKA_RETURN_ERRORS=true

CLIENT_USE_SERVICE_DISCOVERY=true
CLIENT_PRODUCT_GRPC_HOST=172.19.0.1
CLIENT_PRODUCT_GRPC_PORT=50052

OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL=5s
OUTBOX_MAX_RETRY_ATTEMPTS=5
OUTBOX_RETRY_BACKOFF=30s
OUTBOX_CLEANUP_INTERVAL=1h
OUTBOX_RETENTION_PERIOD=24h
