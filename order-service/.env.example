APP_ENVIRONMENT="development"
APP_NAME="order-service"
APP_LOGGER_LEVEL=5
APP_TIMEOUT_SHUTDOWN=10s

HTTP_SERVER_HOST=192.168.0.107
HTTP_SERVER_PORT=8083
HTTP_SERVER_GRACE_PERIOD=10s
HTTP_SERVER_REQUEST_TIMEOUT_PERIOD=30s
HTTP_SERVER_READ_TIMEOUT=30s
HTTP_SERVER_WRITE_TIMEOUT=30s
HTTP_SERVER_IDLE_TIMEOUT=120s
HTTP_SERVER_READ_HEADER_TIMEOUT=10s
HTTP_SERVER_MAX_HEADER_BYTES=1048576
HTTP_SERVER_HSTS_MAX_AGE=3600
HTTP_SERVER_RATE_LIMITER=1000

CONSUL_ADDRESS=localhost:8500
CONSUL_ENABLED=true

POSTGRES_HOST="localhost"
POSTGRES_PORT=15433
POSTGRES_DB="order_db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_SSL_MODE="disable"
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_MAX_OPEN_CONNS=32
POSTGRES_MAX_CONN_LIFETIME=60s

REDIS_ADDRS=localhost:6379,localhost:6380,localhost:6381,localhost:6382,localhost:6383,localhost:6384
REDIS_PASSWORD=supersecret
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=1s
REDIS_MIN_IDLE_CONN=8
REDIS_MAX_IDLE_CONN=12
REDIS_MAX_ACTIVE_CONN=32
REDIS_MAX_CONN_LIFETIME=60s

KAFKA_BROKERS=localhost:9092,localhost:9092,localhost:9092
KAFKA_RETRY_MAX=3
KAFKA_FLUSH_FREQUENCY=500
KAFKA_RETURN_SUCCESS=true
KAFKA_RETURN_ERRORS=true

SAGA_EXECUTION_MODE=async
SAGA_DEFAULT_EXECUTION_TIMEOUT=30m
SAGA_MAX_CONCURRENT=1000
SAGA_DEFAULT_MAX_RETRIES=3
SAGA_DEFAULT_RETRY_DELAY=2s
SAGA_EXPONENTIAL_BACKOFF=true
SAGA_MAX_RETRY_DELAY=1m
SAGA_RECOVERY_ENABLED=true
SAGA_RECOVERY_INTERVAL=5m
SAGA_RECOVERY_BATCH_SIZE=100
SAGA_MAX_RECOVERY_AGE=24h
SAGA_STATE_RETENTION=720h
SAGA_PURGE_COMPLETED=true
SAGA_PURGE_INTERVAL=24h

TEMPORAL_API_KEY=temporalapikey
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=order-saga-task-queue
TEMPORAL_WORKFLOW_TIMEOUT=90m
TEMPORAL_COMPENSATION_WORKFLOW_TIMEOUT=15m
TEMPORAL_RETRY_INTERVAL=500ms
TEMPORAL_BACKOFF_COEFFICIENT=2.0
TEMPORAL_MAX_ATTEMPTS=3
TEMPORAL_MAX_INTERVAL=1m

JOB_RECOVERY_ENABLED=true
JOB_RECOVERY_INTERVAL=5m
JOB_RECOVERY_MAX_RETRIES=5
JOB_RECOVERY_MAX_AGE=24h
JOB_RECOVERY_TIMEOUT=30s
JOB_RECOVERY_MAX_ROWS_FETCH=100
JOB_RECOVERY_REDIS_LOCK_TTL=10m
JOB_RECOVERY_REDIS_LOCK_BACKOFF=100ms
JOB_RECOVERY_REDIS_LOCK_MAX_RETRIES=10

CLIENT_USE_SERVICE_DISCOVERY=true
CLIENT_PRODUCT_GRPC_HOST=0.0.0.0
CLIENT_PRODUCT_GRPC_PORT=50052
CLIENT_FULFILLMENT_GRPC_HOST=0.0.0.0
CLIENT_FULFILLMENT_GRPC_PORT=50055

OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL=5s
OUTBOX_MAX_RETRY_ATTEMPTS=5
OUTBOX_RETRY_BACKOFF=30s
OUTBOX_CLEANUP_INTERVAL=1h
OUTBOX_RETENTION_PERIOD=24h

