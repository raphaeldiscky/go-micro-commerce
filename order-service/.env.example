APP_ENVIRONMENT="release"
SERVICE_NAME="order-service"

HTTP_SERVER_HOST="0.0.0.0"
HTTP_SERVER_PORT=8083
HTTP_SERVER_GRACE_PERIOD=15
HTTP_SERVER_REQUEST_TIMEOUT_PERIOD=10

DB_USER="postgres"
DB_PASSWORD="postgres"
DB_HOST="localhost"
DB_PORT=35432
DB_NAME="postgres"
DB_SSL_MODE="disable"
DB_MAX_IDLE_CONN=10
DB_MAX_OPEN_CONN=32
DB_CONN_MAX_LIFETIME=60

REDIS_ADDRS=localhost:6379,localhost:6380,localhost:6381,localhost:6382,localhost:6383,localhost:6384
REDIS_PASSWORD=supersecret
REDIS_DIAL_TIMEOUT=5
REDIS_READ_TIMEOUT=3
REDIS_WRITE_TIMEOUT=1
REDIS_MIN_IDLE_CONN=8
REDIS_MAX_IDLE_CONN=12
REDIS_MAX_ACTIVE_CONN=32
REDIS_MAX_CONN_LIFETIME=60

KAFKA_BROKERS="localhost:9092,localhost:9092,localhost:9092"
KAFKA_RETRY_MAX=3
KAFKA_FLUSH_FREQUENCY=500
KAFKA_RETURN_SUCCESS=true

TEMPORAL_API_KEY='temporalapikey'
TEMPORAL_NAMESPACE='go-micro-commerce'
TEMPORAL_ADDRESS='localhost:7233'

LOGGER_LEVEL=4

CONSUL_ENABLED=true
CONSUL_ADDRESS=localhost:8500
SERVICE_NAME=order-service
SERVICE_HOST=192.168.0.107

# Client Configuration for gRPC services
USE_SERVICE_DISCOVERY=true
PRODUCT_GRPC_HOST="localhost"
PRODUCT_GRPC_PORT=50052

# Outbox Publisher Configuration (missing from earlier)
OUTBOX_PUBLISHER_MAX_WORKERS=10
OUTBOX_PUBLISHER_BATCH_SIZE=100
OUTBOX_PUBLISHER_RETRY_INTERVAL=5
OUTBOX_PUBLISHER_MAX_RETRIES=3

# Jobs Configuration
JOBS_SAGA_RECOVERY_ENABLED=true
JOBS_SAGA_RECOVERY_INTERVAL=5m
JOBS_SAGA_RECOVERY_MAX_RETRIES=5
JOBS_SAGA_RECOVERY_MAX_AGE=24h

# Additional jobs can be added here
# JOBS_CLEANUP_ENABLED=true
# JOBS_CLEANUP_INTERVAL=1h