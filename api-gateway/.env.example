APP_ENVIRONMENT="development"
SERVICE_NAME="api-gateway"


# Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# JWT Configuration
JWT_SECRET=secret
JWT_EXPIRATION_TIME=24h
JWT_REFRESH_TIME=72h
JWT_ISSUER=api-gateway
JWT_TOKEN_LOOKUP=header:Authorization
JWT_AUTH_SCHEME=Bearer
JWT_SIGNING_METHOD=HS256
JWT_CONTEXT_KEY=user

# Service Discovery Configuration
SERVICE_DISCOVERY_TYPE=consul
SERVICE_DISCOVERY_ADDRESS=localhost:8500
SERVICE_DISCOVERY_TIMEOUT=5s
SERVICE_DISCOVERY_CONSUL_ADDRESS=localhost:8500
SERVICE_DISCOVERY_CONSUL_DATACENTER=dc1
SERVICE_DISCOVERY_CONSUL_TOKEN=

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_BURST_LIMIT=10

# Tracing Configuration
TRACING_ENABLED=true
TRACING_URL=http://otel-collector:4318/v1/traces
TRACING_SERVICE_NAME=api-gateway
TRACING_SAMPLING_RATE=0.1
TRACING_ENVIRONMENT=development
TRACING_BATCH_TIMEOUT=5
TRACING_EXPORT_TIMEOUT=30
TRACING_METADATA=api-gateway

# Metrics Configuration
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_PORT=9090
