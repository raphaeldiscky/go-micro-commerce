APP_NAME="api-gateway"
APP_ENVIRONMENT="development"
APP_TIMEOUT_SHUTDOWN=10s
APP_TIMEOUT_PROXY_REQUEST=10s
APP_LOGGER_LEVEL=5

HTTP_SERVER_HOST=192.168.0.107
HTTP_SERVER_PORT=8080
HTTP_SERVER_GRACE_PERIOD=10s
HTTP_SERVER_REQUEST_TIMEOUT_PERIOD=30s
HTTP_SERVER_READ_TIMEOUT=30s
HTTP_SERVER_WRITE_TIMEOUT=30s
HTTP_SERVER_IDLE_TIMEOUT=120s
HTTP_SERVER_READ_HEADER_TIMEOUT=10s
HTTP_SERVER_MAX_HEADER_BYTES=1048576
HTTP_SERVER_HSTS_MAX_AGE=3600
HTTP_SERVER_RATE_LIMITER=1000

JWT_SECRET=secret
JWT_EXPIRATION_TIME=24h
JWT_REFRESH_TIME=72h
JWT_ISSUER=auth-service
JWT_TOKEN_LOOKUP=header:Authorization
JWT_AUTH_SCHEME=Bearer
JWT_SIGNING_METHOD=HS256
JWT_CONTEXT_KEY=user
JWT_ALLOWED_ALGS=HS256

SERVICE_DISCOVERY_TYPE=consul
SERVICE_DISCOVERY_ADDRESS=localhost:8500
SERVICE_DISCOVERY_TIMEOUT=5s
SERVICE_DISCOVERY_CONSUL_ADDRESS=localhost:8500
SERVICE_DISCOVERY_CONSUL_DATACENTER=dc1
SERVICE_DISCOVERY_CONSUL_TOKEN=token
SERVICE_DISCOVERY_CONSUL_REFRESH_INTERVAL=5s

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_BURST_LIMIT=10

TRACING_ENABLED=true
TRACING_URL=http://localhost:4318
TRACING_SERVICE_NAME=api-gateway
TRACING_SAMPLING_RATE=0.1
TRACING_ENVIRONMENT=development
TRACING_BATCH_TIMEOUT=5
TRACING_EXPORT_TIMEOUT=30

METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_PORT=9090
