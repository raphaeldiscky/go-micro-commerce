# Production Environment - Configuration Example
# Copy this file to terraform.tfvars and customize for your environment

# ============================================================================
# GCP Project Configuration
# ============================================================================
project_id  = "go-micro-commerce"   # REQUIRED: Update with your GCP project ID
region      = "asia-southeast2"     # GCP region (Jakarta)
zone        = "asia-southeast2-a"   # GCP zone for cluster (remove this if want to have)
environment = "prod"

# ============================================================================
# Network Configuration
# ============================================================================
network_name     = "go-micro-commerce-prod"  # VPC network name
subnet_cidr      = "10.0.0.0/20"             # Primary subnet CIDR (4096 IPs)
pods_cidr        = "10.4.0.0/14"             # Secondary range for pods (262144 IPs)
services_cidr    = "10.8.0.0/20"             # Secondary range for services (4096 IPs)
enable_flow_logs = true                      # Enable VPC flow logs for monitoring
enable_nat       = true                      # Enable Cloud NAT for private nodes

# ============================================================================
# GKE Cluster Configuration
# ============================================================================
cluster_name           = "go-micro-commerce-prod"  # GKE cluster name
kubernetes_version     = "1.33"                    # Kubernetes version
release_channel        = "REGULAR"                 # Release channel (RAPID, REGULAR, STABLE)
max_pods_per_node      = 110                       # Maximum pods per node
enable_workload_identity = true                    # Enable Workload Identity for service accounts

# ============================================================================
# Stateful Node Pool (Databases: PostgreSQL, Kafka, Redis)
# Regular VMs for reliable performance
# ============================================================================
stateful_pool_enabled      = true                 # Enable stateful node pool
stateful_pool_node_count   = 3                    # Fixed node count (no autoscaling)
stateful_pool_machine_type = "e2-medium"          # 1 vCPU, 4GB RAM
stateful_pool_disk_size_gb = 35                   # 40GB balanced disk per node (3 nodes × 35GB = 105GB)
stateful_pool_disk_type    = "pd-balanced"        # Balanced disk for cost efficiency, or use SSD (pd-ssd) for database performance

# ============================================================================
# Stateless Node Pool (Microservices)
# Spot VMs with autoscaling for 60-91% cost savings
# ============================================================================
stateless_pool_enabled      = true             # Enable stateless node pool
stateless_pool_min_nodes    = 1                # Minimum nodes (autoscaling)
stateless_pool_max_nodes    = 1                # Maximum nodes (autoscaling)
stateless_pool_machine_type = "e2-standard-2"  # 2 vCPU, 8GB RAM (Spot VM)
stateless_pool_disk_size_gb = 25            # 25GB balanced disk per node (1 nodes × 25GB = 25GB)
stateless_pool_disk_type    = "pd-balanced" # Balanced disk for cost efficiency

# ============================================================================
# Monitoring Node Pool (Observability: Prometheus, Grafana, Loki, Tempo)
# Regular VMs with autoscaling for reliability
# ============================================================================
monitoring_pool_enabled      = true             # Enable monitoring node pool
monitoring_pool_min_nodes    = 2                # Minimum nodes (autoscaling)
monitoring_pool_max_nodes    = 2                # Maximum nodes (autoscaling)
monitoring_pool_machine_type = "e2-standard-2"  # 2 vCPU, 8GB RAM
monitoring_pool_disk_size_gb = 25               # 25GB balanced disk per node (2 node × 25GB = 50GB)
monitoring_pool_disk_type    = "pd-balanced"    # Balanced disk for cost efficiency

# ============================================================================
# Control Plane Node Pool (Operators: ArgoCD, ESO, CNPG, Strimzi, Redis)
# Regular VMs with autoscaling for control plane
# ============================================================================
control_plane_pool_enabled      = true              # Enable control plane node pool
control_plane_pool_min_nodes    = 1                 # Minimum nodes (autoscaling)
control_plane_pool_max_nodes    = 1                 # Maximum nodes (autoscaling)
control_plane_pool_machine_type = "e2-standard-2"   # 2 vCPU, 8GB RAM
control_plane_pool_disk_size_gb = 20                # 20GB balanced disk per node (1 node × 20GB = 20GB)
control_plane_pool_disk_type    = "pd-balanced"     # Balanced disk for cost efficiency

# ============================================================================
# Gateway Node Pool (Ingress: Traefik, Apollo Router, API Gateway)
# Regular VMs with autoscaling for gateway reliability
# ============================================================================
gateway_pool_enabled      = true          # Enable gateway node pool
gateway_pool_min_nodes    = 1             # Minimum nodes (autoscaling)
gateway_pool_max_nodes    = 1             # Maximum nodes (autoscaling)
gateway_pool_machine_type = "e2-medium"   # 1 vCPU, 4GB RAM
gateway_pool_disk_size_gb = 15            # 15GB balanced disk per node
gateway_pool_disk_type    = "pd-balanced" # Balanced disk for cost efficiency

# ============================================================================
# Kubernetes Operators and Platform Components
# ============================================================================

# External Secrets Operator (syncs secrets from Google Secret Manager)
eso_namespace                   = "external-secrets"
eso_chart_version               = "1.0.0"
eso_replicas                    = 1  
eso_gcp_service_account_name    = "external-secrets-operator"
eso_k8s_service_account_name    = "external-secrets-sa"
eso_create_cluster_secret_store = true
eso_cluster_secret_store_name   = "gcp-secret-manager"

# CloudNative PostgreSQL Operator
cnpg_namespace     = "cnpg-system"
cnpg_chart_version = "0.26.1"

# Strimzi Kafka Operator
kafka_namespace        = "kafka-system"
kafka_chart_version    = "0.48.0"
kafka_watch_namespaces = [] # Empty = watch all namespaces

# Redis Operator
redis_namespace        = "redis-system"
redis_chart_version    = "0.22.2"
redis_watch_namespaces = [] # Empty = watch all namespaces

# Monitoring Stack
monitoring_namespace                = "monitoring"
kube_prometheus_stack_chart_version = "79.5.0"
grafana_admin_password              = ""                            # Change this!
grafana_enable_ingress              = true                          # Enable HTTPS access via Traefik
grafana_domain_name                 = "grafana.api.your_domain.com" # Update this for your domain
grafana_tls_issuer                  = "letsencrypt-prod"
prometheus_retention                = "30d"                         # 30 days retention
prometheus_storage_size             = "4Gi"                         # 4Gi optimized for learning/testing
loki_chart_version                  = "6.46.0"
loki_storage_size                   = "2Gi"                         # 2Gi for log storage
tempo_chart_version                 = "1.24.0"
tempo_storage_size                  = "1Gi"                         # 1Gi for tracing data

# ArgoCD
argocd_namespace         = "argocd"
argocd_chart_version     = "9.1.2"
argocd_admin_password    = ""                                                       # Leave empty for auto-generated
argocd_git_repo_url      = ""                                                       # Update this!
argocd_git_repo_path     = "deployments/k8s"
argocd_enable_bootstrap  = true                                                     # Set to true after configuring git repo
argocd_enable_ingress    = true                                                     # Enable HTTPS access via Traefik
argocd_domain_name       = "argocd.api.your_domain.com"                             # Update this for your domain
argocd_tls_issuer        = "letsencrypt-prod"

# ============================================================================
# ArgoCD Git Repository Credentials (for private repositories)
# ============================================================================
# SECURITY: DO NOT commit actual credentials to git!
# Choose ONE of the following authentication methods:

# -----------------------------------------------------------------------------
# METHOD 1: HTTPS with Personal Access Token (Simpler, Good for Testing)
# -----------------------------------------------------------------------------
# 1. Create GitHub Personal Access Token:
#    - Go to: https://github.com/settings/tokens
#    - Click: "Generate new token" → "Generate new token (classic)"
#    - Scopes: Select "repo" (Full control of private repositories)
#    - Generate and copy the token
#
# 2. Update repository URL to HTTPS format:
#    argocd_git_repo_url = "https://github.com/your_github/go-micro-commerce.git"
#
# 3. Set credentials via environment variable (RECOMMENDED):
#    export TF_VAR_argocd_git_username="git"
#    export TF_VAR_argocd_git_token="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#    terraform apply
#
# 4. OR pass at runtime:
#    terraform apply -var="argocd_git_token=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#
# Note: Update ApplicationSets to use HTTPS URLs in deployments/k8s/apps/applicationsets/*.yaml

argocd_git_username = "git"  # Default username for HTTPS token auth
# argocd_git_token  = ""     # or set via TF_VAR_argocd_git_token 

# -----------------------------------------------------------------------------
# METHOD 2: SSH with Deploy Key (More Secure, Recommended for Production)
# -----------------------------------------------------------------------------
# 1. Generate SSH key pair:
#    ssh-keygen -t ed25519 -C "argocd@your_domain.com" -f ~/.ssh/argocd-repo -N ""
#
# 2. Add public key to GitHub (Deploy Key - recommended):
#    - Go to: https://github.com/your_github/go-micro-commerce/settings/keys
#    - Click: "Add deploy key"
#    - Title: "ArgoCD Production GKE"
#    - Key: Paste contents of: cat ~/.ssh/argocd-repo.pub
#    - Allow write access: NO (read-only is sufficient)
#
# 3. Repository URL is already in SSH format (see line 135 above):
#    argocd_git_repo_url = "git@github.com:your_github/go-micro-commerce.git"
#
# 4. Set private key via environment variable (RECOMMENDED):
#    export TF_VAR_argocd_git_ssh_private_key=$(cat ~/.ssh/argocd-repo)
#    terraform apply
#
# 5. Update ApplicationSets to use SSH URLs:
#    Edit: deployments/k8s/apps/applicationsets/infrastructure.yaml
#    Edit: deployments/k8s/apps/applicationsets/workloads.yaml
#    Change: repoURL: https://github.com/your_github/go-micro-commerce.git
#    To:     repoURL: git@github.com:your_github/go-micro-commerce.git
#
# 6. Verify SSH connection works:
#    ssh -T git@github.com -i ~/.ssh/argocd-repo
#    # Expected: "Hi your_github! You've successfully authenticated..."

argocd_git_ssh_private_key = ""  # or set via TF_VAR_argocd_git_ssh_private_key 

# cert-manager (for automated TLS certificates)
cert_manager_namespace                       = "cert-manager"
cert_manager_chart_version                   = "v1.19.1"
cert_manager_replicas                        = 1
cert_manager_create_cluster_issuers          = true
cert_manager_letsencrypt_email               = ""         # Update this! Used for Let's Encrypt notifications
cert_manager_letsencrypt_staging_issuer_name = "letsencrypt-staging"
cert_manager_letsencrypt_prod_issuer_name    = "letsencrypt-prod"

# Traefik Ingress Controller
traefik_namespace        = "traefik"
traefik_chart_version    = "37.3.0"
traefik_replicas         = 1                  # 1 replica for testing/learning 
traefik_service_type     = "LoadBalancer"     # LoadBalancer for GKE
traefik_enable_dashboard = true

# ============================================================================
# Cloudflare Configuration
# ============================================================================
# Note: Frontend (go.micro.commerce.your_domain.com) is deployed via Cloudflare Pages
#       This only configures DNS records for backend API

cloudflare_api_token = ""
cloudflare_zone_id   = ""
# API Token Permissions:
# Permissions:
#  Zone:
#    - DNS: Edit
#    - Zone: Read
# Zone Resources:
#  - Include: your_domain.com

# Domain Configuration
domain_name         = "your_domain.com"
api_subdomain       = "api"                         # Results in: api.your_domain.com
enable_api_wildcard = false                         # Set true to create *.api.your_domain.com
enable_argocd_dns   = true                          # Create DNS record for ArgoCD
argocd_subdomain    = "argocd.api"                  # Results in: argocd.api.your_domain.com
enable_grafana_dns  = true                          # Create DNS record for Grafana
grafana_subdomain   = "grafana.api"                 # Results in: grafana.api.your_domain.com