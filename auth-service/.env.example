APP_ENVIRONMENT="development"
APP_NAME="auth-service"
APP_LOGGER_LEVEL=5
APP_TIMEOUT_SHUTDOWN=10s

AUTH_VERIFICATION_TOKEN_EXPIRATION=10m

BCRYPT_COST=10

HTTP_SERVER_HOST=192.168.0.107
HTTP_SERVER_PORT=8081
HTTP_SERVER_GRACE_PERIOD=10s
HTTP_SERVER_REQUEST_TIMEOUT_PERIOD=30s
HTTP_SERVER_READ_TIMEOUT=30s
HTTP_SERVER_WRITE_TIMEOUT=30s
HTTP_SERVER_IDLE_TIMEOUT=120s
HTTP_SERVER_READ_HEADER_TIMEOUT=10s
HTTP_SERVER_MAX_HEADER_BYTES=1048576
HTTP_SERVER_HSTS_MAX_AGE=3600
HTTP_SERVER_RATE_LIMITER=1000

CONSUL_ADDRESS=localhost:8500
CONSUL_ENABLED=true

POSTGRES_HOST="localhost"
POSTGRES_PORT=15431
POSTGRES_DB="auth_db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_SSL_MODE="disable"
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_MAX_OPEN_CONNS=32
POSTGRES_MAX_CONN_LIFETIME=60s

KAFKA_BROKERS="localhost:9092,localhost:9093,localhost:9094" # PROD -> kafka-1:9092,kafka-2:9092,kafka-3:9092
KAFKA_RETRY_MAX=3
KAFKA_RETRY_INTERNAL=500s
KAFKA_FLUSH_FREQUENCY=500
KAFKA_RETURN_SUCCESS=true
KAFKA_RETURN_ERRORS=TRUE

JWT_SECRET=secret
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_EXPIRATION_TIME=24h
JWT_REFRESH_TIME=72h
JWT_ISSUER=auth-service
JWT_TOKEN_LOOKUP=header:Authorization
JWT_AUTH_SCHEME=Bearer
JWT_SIGNING_METHOD=RS256
JWT_CONTEXT_KEY=user
JWT_ALLOWED_ALGS=RS256