APP_ENVIRONMENT="development"
APP_NAME="chat-service"
APP_LOGGER_LEVEL=5
APP_TIMEOUT_SHUTDOWN=10s

HTTP_SERVER_HOST=192.168.0.107
HTTP_SERVER_PORT=8085
HTTP_SERVER_GRACE_PERIOD=10s
HTTP_SERVER_REQUEST_TIMEOUT_PERIOD=30s
HTTP_SERVER_READ_TIMEOUT=30s
HTTP_SERVER_WRITE_TIMEOUT=30s
HTTP_SERVER_IDLE_TIMEOUT=120s
HTTP_SERVER_READ_HEADER_TIMEOUT=10s
HTTP_SERVER_MAX_HEADER_BYTES=1048576
HTTP_SERVER_HSTS_MAX_AGE=3600
HTTP_SERVER_RATE_LIMITER=1000

CONSUL_ADDRESS=localhost:8500
CONSUL_ENABLED=true


WS_SERVER_HOST=192.168.0.107
WS_SERVER_PORT=9098
WS_SERVER_GRACE_PERIOD=30s
WS_SERVER_REQUEST_TIMEOUT_PERIOD=30s
WS_SERVER_READ_TIMEOUT=10s
WS_SERVER_WRITE_TIMEOUT=10s
WS_SERVER_IDLE_TIMEOUT=120s
WS_SERVER_READ_HEADER_TIMEOUT=5s
WS_SERVER_MAX_HEADER_BYTES=1048576
WS_SERVER_HSTS_MAX_AGE=31536000
WS_SERVER_RATE_LIMITER=1000
WS_SERVER_READ_BUFFER_SIZE=1024
WS_SERVER_WRITE_BUFFER_SIZE=1024

GRPC_SERVER_SERVICE_NAME="chat-service-grpc"
GRPC_SERVER_HOST=192.168.0.107
GRPC_SERVER_PORT=50055
GRPC_SERVER_GRACE_PERIOD=10s

POSTGRES_HOST="localhost"
POSTGRES_PORT=15435
POSTGRES_DB="fulfillment_db"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_SSL_MODE="disable"
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_MAX_OPEN_CONNS=32
POSTGRES_MAX_CONN_LIFETIME=60s

REDIS_ADDRS=localhost:6379,localhost:6380,localhost:6381,localhost:6382,localhost:6383,localhost:6384
REDIS_PASSWORD=supersecret
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_MIN_IDLE_CONN=8
REDIS_MAX_IDLE_CONN=12
REDIS_MAX_ACTIVE_CONN=32
REDIS_MAX_CONN_LIFETIME=60s

KAFKA_BROKERS="localhost:9092,localhost:9092,localhost:9092"
KAFKA_RETRY_MAX=3
KAFKA_FLUSH_FREQUENCY=500
KAFKA_RETURN_SUCCESS=true
KAFKA_RETURN_ERRORS=true

OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL=5s
OUTBOX_MAX_RETRY_ATTEMPTS=5
OUTBOX_RETRY_BACKOFF=30s
OUTBOX_CLEANUP_INTERVAL=1h
OUTBOX_RETENTION_PERIOD=24h

# Connection Service Configuration
# JWKS configuration (recommended for production - auto-refresh keys from auth-service)
CONN_JWKS_URL=http://localhost:8081/.well-known/jwks.json
CONN_JWKS_CACHE_TTL=1h
CONN_JWKS_REFRESH_INTERVAL=15m

# File-based keys (fallback if JWKS unavailable)
# CONN_PUBLIC_KEY_PATH=./keys/public.pem

# Chat Node Configuration
CONN_DEFAULT_NODE_ADDRESS=ws://localhost:9098
CONN_MAX_CONNECTIONS=10000
CONN_CONSUL_ADDRESS=localhost:8500
CONN_CHAT_SERVICE_NAME=chat-service-websocket
