							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"let res = pm.response.json();",
											"",
											"if (res.data) {",
											"    pm.environment.set(\"access_token\", res.data.access_token);",
											"    pm.environment.set(\"refresh_token\", res.data.refresh_token);",
											"    pm.environment.set(\"token_type\", res.data.token_type || \"Bearer\");",
											"    pm.environment.set(\"expires_in\", res.data.expires_in);",
											"",
											"    console.log(\"Access token and refresh token saved to environment.\");",
